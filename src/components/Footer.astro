---
import { LINKS, SITE, SOCIALS } from "@consts"
import Container from "@components/Container.astro"

type Props = {
  size?: "sm" | "md" | "lg" | "xl" | "2xl"
}

const { size = "md" } = Astro.props
const year = new Date().getFullYear()
const primaryLinks = LINKS.filter(({ HREF }) => HREF !== "/")
const contactLinks = SOCIALS
const legalLinks = [
  { TEXT: "Terms", HREF: "/legal/terms" },
  { TEXT: "Privacy", HREF: "/legal/privacy" },
]
---

<footer class="relative bg-white dark:bg-black">
  <div class="animate">
    <section class="border-t border-black/8 py-6 dark:border-white/12 sm:py-7">
      <Container size={size}>
        <div class="px-1">
          <div class="flex flex-col gap-5 sm:gap-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
              <a href="/" class="flex w-fit items-center gap-2 text-current transition-colors duration-300 ease-in-out hover:text-black dark:hover:text-white">
                <svg class="size-6 shrink-0 fill-current">
                  <use href="/brand.svg#brand"/>
                </svg>
                <span class="text-base font-semibold tracking-tight text-black dark:text-white">{SITE.TITLE}</span>
              </a>

              <div class="flex flex-col gap-4 sm:gap-3 lg:items-end">
                <nav aria-label="Footer links" class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
                  {
                    primaryLinks.map((link) => (
                      <a
                        href={link.HREF}
                        class="inline-flex w-fit text-black/62 transition-colors duration-300 ease-in-out hover:text-black dark:text-white/62 dark:hover:text-white"
                      >
                        {link.TEXT}
                      </a>
                    ))
                  }
                </nav>

                <div class="flex flex-wrap items-center gap-2.5">
                  {
                    contactLinks.map((link) => (
                      <a
                        href={link.HREF}
                        target={link.NAME === "Email" ? undefined : "_blank"}
                        rel={link.NAME === "Email" ? undefined : "noreferrer"}
                        aria-label={link.NAME === "Email" ? `Email ${SITE.TITLE}` : `${SITE.TITLE} on ${link.NAME}`}
                        class="inline-flex size-8 items-center justify-center rounded-full text-black/50 transition-colors duration-300 ease-in-out hover:text-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black/15 dark:text-white/50 dark:hover:text-white dark:focus-visible:ring-white/20"
                      >
                        <svg class="size-4 fill-current">
                          <use href={`/social.svg#${link.ICON}`} />
                        </svg>
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="flex flex-col gap-2 text-sm text-black/42 dark:text-white/38 sm:flex-row sm:items-center sm:justify-between">
              <div>&copy; {year} {SITE.TITLE}</div>
              <nav aria-label="Legal links" class="flex flex-wrap items-center gap-x-4 gap-y-2">
                {
                  legalLinks.map((link) => (
                    <a
                      href={link.HREF}
                      class="inline-flex w-fit transition-colors duration-300 ease-in-out hover:text-black dark:hover:text-white"
                    >
                      {link.TEXT}
                    </a>
                  ))
                }
              </nav>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </div>

</footer>
